# Copy this file to .env and edit the values before `docker compose up -d`.
#
# This stack runs behind a Pangolin / Newt tunnel. Backend services do NOT
# bind host ports — Newt forwards from Pangolin to them by docker service
# name on the `pia-stack` network. Pangolin resource targets look like
# `listmonk:9000`, `cryptpad:3000`, `mkdocs:8000`, etc.
#
# For local testing without Pangolin, hit services from inside the network:
#   docker run --rm --network pia-stack curlimages/curl:latest -sI http://listmonk:9000/

# --- Pangolin / Newt tunnel --------------------------------------------------
# Get NEWT_ID and NEWT_SECRET by registering this host as a "site" (type
# "newt") in your Pangolin admin UI. PANGOLIN_ENDPOINT is the public URL of
# your Pangolin server.
PANGOLIN_ENDPOINT=https://pangolin.example.org
PANGOLIN_NEWT_ID=
PANGOLIN_NEWT_SECRET=

# --- Listmonk ----------------------------------------------------------------
# Change the password before going public.
LISTMONK_DB_USER=listmonk
LISTMONK_DB_PASSWORD=changeme
LISTMONK_DB_NAME=listmonk

# --- linuxserver image user mapping (mkdocs-site-server) --------------------
# Match these to the user that owns ./site/ on the host so Nginx can read it.
# `id -u` and `id -g` on the host.
USER_ID=1000
GROUP_ID=1000
TZ=Etc/UTC

# --- Code Server (web IDE for editing docs + running mkdocs build) ----------
# Vanilla upstream image works for everyone but has no mkdocs preinstalled —
# install it once in the workspace terminal: `pip install --user "mkdocs-material[recommended]"`.
# PIA's deployment uses a private prebuilt image with mkdocs + plugins:
#     CODE_SERVER_IMAGE=gitea.bnkops.com/admin/code-server:latest
CODE_SERVER_IMAGE=codercom/code-server:latest
CODE_SERVER_PORT=8889
CODE_SERVER_PASSWORD=changeme

# --- CryptPad (only used with `--profile session`) ---------------------------
# CryptPad bakes these into client-side bundles on first boot — set them to
# the public URLs your Pangolin resources will serve before bringing CryptPad
# up. Both must be routed via Pangolin or the editor surface won't render.
CRYPTPAD_MAIN_DOMAIN=https://pad.example.org
CRYPTPAD_SANDBOX_DOMAIN=https://pad-sandbox.example.org
